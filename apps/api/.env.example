# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/taskeasy?retryWrites=true&w=majority"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-64-char-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-a-different-64-char-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ─── Cloudinary (file uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Messaging / Delivery ────────────────────────────────────────────────────
EMAIL_PROVIDER="smtp" # smtp | sendgrid | ses
SENDGRID_API_KEY=""
SENDGRID_FROM="TaskEasy <no-reply@taskeasy.app>"
AWS_SES_REGION="ap-south-1"
AWS_SES_ACCESS_KEY_ID=""
AWS_SES_SECRET_ACCESS_KEY=""
AWS_SES_FROM="TaskEasy <no-reply@taskeasy.app>"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_GRAPH_API_VERSION="v20.0"

# ─── Google / Microsoft SSO ──────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:5000/api/auth/sso/google/callback"
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""
MICROSOFT_OAUTH_TENANT_ID="common"
MICROSOFT_OAUTH_REDIRECT_URI="http://localhost:5000/api/auth/sso/microsoft/callback"

# ─── Google Sync / Export ─────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_CALENDAR_ID=""
GOOGLE_SHEETS_FOLDER_ID=""

# ─── AI (Mistral — used by FMS "Generate with AI") ────────────────────────────
# Leave blank to fall back to a clearly-labeled placeholder workflow.
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-large-latest"

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="TaskEasy <no-reply@taskeasy.app>"

# ─── Seed credentials (used only by prisma/seed.ts — remove after first run) ─
SEED_TENANT_NAME="Demo Company"
SEED_SUPER_ADMIN_EMAIL="superadmin@taskeasy.app"
SEED_SUPER_ADMIN_PASSWORD="Admin@1234"
SEED_ADMIN_EMAIL="admin@taskeasy.app"
SEED_ADMIN_PASSWORD="Admin@1234"
SEED_EMPLOYEE_EMAIL="employee@taskeasy.app"
SEED_EMPLOYEE_PASSWORD="Employee@1234"
