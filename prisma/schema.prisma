// ============================================================
// BULK IMPORT
// ============================================================

enum BulkImportStatus {
  PENDING
  VALIDATING
  IMPORTING
  COMPLETED
  PARTIAL
  FAILED
}

enum BulkImportRowStatus {
  VALID
  INVALID
  IMPORTED
  FAILED
  SKIPPED
  DUPLICATE
}

model BulkImportBatch {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String            @db.ObjectId
  moduleName   String
  fileName     String
  uploadedById String            @db.ObjectId
  totalRows    Int               @default(0)
  validRows    Int               @default(0)
  invalidRows  Int               @default(0)
  importedRows Int               @default(0)
  failedRows   Int               @default(0)
  skippedRows  Int               @default(0)
  status       BulkImportStatus  @default(PENDING)
  importMode   String            @default("valid_only")
  createdAt    DateTime          @default(now())
  completedAt  DateTime?

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  uploadedBy User            @relation("BulkImportUploader", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rows       BulkImportRow[]

  @@index([tenantId, moduleName, createdAt])
  @@index([tenantId, uploadedById])
  @@map("bulkImportBatches")
}

model BulkImportRow {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  batchId         String              @db.ObjectId
  rowNumber       Int
  rawData         Json
  normalizedData  Json?
  rowStatus       BulkImportRowStatus
  errors          Json?
  createdRecordId String?
  createdAt       DateTime            @default(now())

  batch BulkImportBatch @relation(fields: [batchId], references: [id])

  @@index([batchId, rowStatus])
  @@map("bulkImportRows")
}
