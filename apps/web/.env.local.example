# ─────────────────────────────────────────────────────────────────────────────
# TaskEasy Web — Environment Variables
# Copy this file to .env.local and fill in real values before starting.
# NEVER commit .env.local — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── API base URL ──────────────────────────────────────────────────────────────
# Local dev (API running on port 5000):
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Staging / Production — replace with your deployed API URL:
# NEXT_PUBLIC_API_URL=https://api.taskeasy.app/api

# ── Cloudinary ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
